      "id": "797b9223-8b8c-45ff-af9d-96d778304964",
      "name": "📄 Extraer Texto (PDF / Word)",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1,
      "position": [
        560,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.text || $input.first().json.data || '';\n\nlet cleaned = text\n  .replace(/\\r\\n/g, '\\n')\n  .replace(/\\n{3,}/g, '\\n\\n')\n  .replace(/[ \\t]{2,}/g, ' ')\n  .trim();\n\ncleaned = cleaned.replace(/[^\\x20-\\x7E\\n\\u00C0-\\u024F]/g, '');\n\nconst words = cleaned.split(/\\s+/);\nconst chunkSize = 500;\nconst overlap = 50;\nconst chunks = [];\n\nfor (let i = 0; i < words.length; i += chunkSize - overlap) {\n  const chunk = words.slice(i, i + chunkSize).join(' ');\n  if (chunk.trim().length > 50) {\n    chunks.push({\n      chunk_text: chunk,\n      chunk_index: chunks.length,\n      source_file: $('📁 Google Drive — Nuevo Archivo').first().json.name || 'desconocido',\n      source_id: $('📁 Google Drive — Nuevo Archivo').first().json.id || '',\n      total_words: words.length,\n      created_at: new Date().toISOString()\n    });\n  }\n}\n\nreturn chunks.map(c => ({ json: c }));"
      },
      "id": "a5a21c81-5016-4242-8a79-57a3a47fbb15",
      "name": "🧹 Limpiar y Dividir en Chunks",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:11434/api/embeddings",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "nomic-embed-text"
            },
            {
              "name": "prompt",
              "value": "={{ $json.chunk_text }}"
            }
          ]
        },
        "options": {}
      },
      "id": "0b26f521-eba8-47b8-b59a-cd80ff926e92",
      "name": "🧠 Generar Embedding (Ollama)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        288,
        304
      ]
    },
    {
      "parameters": {
        "jsCode": "const embeddingData = $input.first().json;\nconst embedding = embeddingData.embedding || [];\nconst chunk = $('🧹 Limpiar y Dividir en Chunks').first().json;\n\nreturn [{\n  json: {\n    content: chunk.chunk_text,\n    embedding: embedding,\n    metadata: {\n      source_file: chunk.source_file,\n      source_id: chunk.source_id,\n      chunk_index: chunk.chunk_index,\n      total_words: chunk.total_words\n    },\n    created_at: chunk.created_at\n  }\n}];"
      },
      "id": "55c79df8-a161-4b57-9d57-c8446617887f",
