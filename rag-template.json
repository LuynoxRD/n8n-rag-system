    {
      "parameters": {
        "jsCode": "const error = $input.first().json;\nconst workflowName = $workflow.name;\nconst timestamp = new Date().toISOString();\n\nlet archivoFallido = 'desconocido';\ntry {\n  archivoFallido = $('📁 Google Drive — Nuevo Archivo').first().json.name || 'desconocido';\n} catch(e) {}\n\nreturn [{\n  json: {\n    archivo: archivoFallido,\n    workflow: workflowName,\n    error: error.message || JSON.stringify(error),\n    nodo_fallido: $execution.lastNodeExecuted || 'desconocido',\n    timestamp\n  }\n}];"
      },
